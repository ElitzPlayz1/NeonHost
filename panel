# -------------------------------
# INSTALL DEPENDENCIES
# -------------------------------
echo "рҹ“Ұ Installing Dependencies..."
apt update -y
apt upgrade -y

apt install -y curl wget git unzip software-properties-common

add-apt-repository universe -y
apt update -y

apt install -y php php-cli php-mbstring php-xml php-bcmath php-curl php-zip mysql-server nginx tar

# -------------------------------
# INSTALL COMPOSER
# -------------------------------
echo "рҹ“Ҙ Installing Composer..."
cd ~
curl -sS https://getcomposer.org/installer | php
mv composer.phar /usr/local/bin/composer

# -------------------------------
# DOWNLOAD PANEL
# -------------------------------
echo "рҹ“Ұ Downloading Panel..."
mkdir -p /var/www/pterodactyl
cd /var/www/pterodactyl

curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz
tar -xzvf panel.tar.gz

chmod -R 755 storage/* bootstrap/cache/

# -------------------------------
# ENV SETUP
# -------------------------------
echo "вҡҷпёҸ Setting up environment..."
cp .env.example .env
composer install --no-dev --optimize-autoloader

php artisan key:generate --force

# -------------------------------
# DATABASE SETUP
# -------------------------------
echo "рҹӣўпёҸ Setting up MySQL..."

mysql -u root <<EOF
CREATE DATABASE panel;
CREATE USER 'ptero'@'127.0.0.1' IDENTIFIED BY 'StrongPassword123!';
GRANT ALL PRIVILEGES ON panel.* TO 'ptero'@'127.0.0.1';
FLUSH PRIVILEGES;
EOF

# -------------------------------
# AUTO CONFIG
# -------------------------------
php artisan p:environment:setup <<EOF
https://localhost
yes
UTC
yes
file
redis
EOF

php artisan p:environment:database <<EOF
127.0.0.1
3306
panel
ptero
StrongPassword123!
EOF

php artisan migrate --seed --force

# -------------------------------
# ADMIN SETUP
# -------------------------------
echo ""
echo "рҹ‘‘ Do you want Administrator account?"
read -p "Type yes or no: " admin_choice

if [ "$admin_choice" = "yes" ]; then

    read -p "First Name: " fname
    read -p "Last Name: " lname
    read -p "Username: " uname
    read -p "Email: " email
    read -p "Password: " pass
    read -p "Confirm Password: " cpass

    if [ "$pass" != "$cpass" ]; then
        echo "вқҢ Password mismatch!"
        exit 1
    fi

    php artisan p:user:make <<EOF
yes
$email
$uname
$fname
$lname
$pass
EOF

fi

# -------------------------------
# NGINX SETUP
# -------------------------------
echo "рҹҢҗ Configuring Nginx..."

cat > /etc/nginx/sites-available/pterodactyl <<EOL
server {
    listen 8080;
    server_name _;

    root /var/www/pterodactyl/public;
    index index.php;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.1-fpm.sock;
    }

    location ~ /\.ht {
        deny all;
    }
}
EOL

ln -s /etc/nginx/sites-available/pterodactyl /etc/nginx/sites-enabled/
systemctl restart nginx

