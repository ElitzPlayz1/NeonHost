#!/bin/bash

clear

echo "====================================="
echo "           POWERED BY"
sleep 1
clear

echo "███████╗██╗     ██╗████████╗███████╗"
echo "██╔════╝██║     ██║╚══██╔══╝██╔════╝"
echo "█████╗  ██║     ██║   ██║   ███████╗"
echo "██╔══╝  ██║     ██║   ██║   ╚════██║"
echo "███████╗███████╗██║   ██║   ███████║"
echo "╚══════╝╚══════╝╚═╝   ╚═╝   ╚══════╝"

echo ""
echo "        ELITZPLAYZYT INSTALLER"
echo "====================================="

sleep 3

echo "🚀 Starting Installation..."

# ROOT CHECK
if [ "$EUID" -ne 0 ]; then
  echo "❌ Run as root (sudo su)"
  exit
fi

# UPDATE SYSTEM
apt update -y && apt upgrade -y

# INSTALL BASIC PACKAGES
apt install -y curl wget git unzip software-properties-common

add-apt-repository universe -y
apt update -y

# INSTALL PHP + MYSQL
apt install -y php php-cli php-mbstring php-xml php-bcmath php-curl php-zip mysql-server tar

# INSTALL COMPOSER
cd ~
curl -sS https://getcomposer.org/installer | php
mv composer.phar /usr/local/bin/composer

# DOWNLOAD PANEL
mkdir -p /var/www/pterodactyl
cd /var/www/pterodactyl

curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz
tar -xzvf panel.tar.gz

chmod -R 755 storage/* bootstrap/cache/

# SETUP ENV
cp .env.example .env
composer install --no-dev --optimize-autoloader
php artisan key:generate --force

# DATABASE SETUP
mysql -u root <<EOF
CREATE DATABASE panel;
CREATE USER 'ptero'@'127.0.0.1' IDENTIFIED BY 'StrongPassword123!';
GRANT ALL PRIVILEGES ON panel.* TO 'ptero'@'127.0.0.1';
FLUSH PRIVILEGES;
EOF

# PANEL CONFIG
php artisan p:environment:setup <<EOF
http://localhost
yes
UTC
yes
file
redis
EOF

php artisan p:environment:database <<EOF
127.0.0.1
3306
panel
ptero
StrongPassword123!
EOF

php artisan migrate --seed --force

# =========================
# USER SETUP
# =========================

echo ""
echo "====================================="
echo "        USER SETUP"
echo "====================================="

read -p "Create Administrator? (yes/no): " admin

echo ""
echo "👉 Enter Account Details"

read -p "Username: " uname
read -p "Email: " email
read -p "Password: " pass
read -p "Confirm Password: " cpass

if [ "$pass" != "$cpass" ]; then
    echo "❌ Password mismatch!"
    exit 1
fi

if [ "$admin" = "yes" ]; then
php artisan p:user:make <<EOF
yes
$email
$uname
Admin
User
$pass
EOF
echo "👑 Admin Created!"
else
php artisan p:user:make <<EOF
no
$email
$uname
User
Panel
$pass
EOF
echo "👤 User Created!"
fi

# =========================
# START PANEL (IMPORTANT FIX)
# =========================

echo ""
echo "🚀 Starting Panel on port 8080..."

cd /var/www/pterodactyl

nohup php artisan serve --host=0.0.0.0 --port=8080 > /dev/null 2>&1 &

sleep 3

# =========================
# FINAL OUTPUT
# =========================

clear
echo "====================================="
echo "✅ INSTALLATION COMPLETE!"
echo ""
echo "👉 Go to PORTS section"
echo "👉 Open port 8080 to access your panel"
echo "====================================="
